generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id        String   @id @default(cuid())
  title     String
  completed Boolean  @default(false)
  category  String
  priority  String   @default("Medium")
  dueTime   String?
  dateKey   String
  createdAt DateTime @default(now())

  @@index([dateKey])
}